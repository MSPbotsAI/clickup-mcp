# ─── ClickUp Credentials ────────────────────────────────────────────────────
# Required when AUTH_MODE=env (default)
# Get your personal API token from: ClickUp Settings > Apps > API Token
CLICKUP_API_TOKEN=pk_xxxxx

# Optional: override the default ClickUp API base URL
# CLICKUP_BASE_URL=https://api.clickup.com/api/v2

# ─── Transport ───────────────────────────────────────────────────────────────
# stdio  — for Claude Desktop / CLI (default)
# http   — for HTTP gateway deployments
MCP_TRANSPORT=stdio

# Port for HTTP transport (default: 8080)
# MCP_HTTP_PORT=8080

# Host for HTTP transport (default: 0.0.0.0)
# MCP_HTTP_HOST=0.0.0.0

# ─── Auth Mode ───────────────────────────────────────────────────────────────
# env     — token from CLICKUP_API_TOKEN env var (default)
# gateway — token from X-Clickup-Token HTTP header per request (multi-tenant)
AUTH_MODE=env
